{
  "name": "wavedash-react",
  "version": "1.3.0",
  "description": "React wrapper for Wavedash",
  "main": "./dist/index.cjs",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@wvdsh/sdk-js": "^1.3.15",
    "react": "^19.2.6",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@types/use-sync-external-store": "^1.5.0",
    "use-sync-external-store": "^1.6.0"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "wavedash",
    "wrapper",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "peerDependencies": {
    "@wvdsh/sdk-js": "^1.3.15",
    "react": ">=18"
  }
}
